generator client {
  provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  address   String?
  role      String   @default("USER")
  name      String?
  rg       String?
  cpf      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}